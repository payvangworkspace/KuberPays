/* src/css/Pricing.css */

.pricing-section {
  background-color: #f9fafe;
  padding: 4rem 2rem;
  text-align: center;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

.pricing-container {
  max-width: 1200px;
  margin: 0 auto;
}

.section-title {
  font-size: 2.5rem;
  font-weight: 700;
  color: #1e2a38;
  margin-bottom: 0.5rem;
}

.section-subtitle {
  font-size: 1.2rem;
  color: #6c7a89;
  margin-bottom: 3rem;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2.5rem;
}

.pricing-card {
  background: #fff;
  border-radius: 1.2rem;
  padding: 2.5rem 2rem;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pricing-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
}

.plan-title {
  font-size: 1.6rem;
  font-weight: 600;
  color: #0a58ca;
  margin-bottom: 1rem;
}

.plan-price {
  font-size: 2.2rem;
  font-weight: 700;
  color: #1e2a38;
  margin-bottom: 0.5rem;
}

.setup-fee {
  font-size: 0.95rem;
  color: #777;
  margin-bottom: 1.5rem;
}

.plan-features {
  list-style: none;
  padding: 0;
  margin: 1rem 0 2rem;
  width: 100%;
  text-align: left;
}

.plan-features li {
  font-size: 0.95rem;
  color: #333;
  margin-bottom: 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.feature-icon {
  color: #0a58ca;
  font-size: 1rem;
  flex-shrink: 0;
}

.btn-get-started {
  background: linear-gradient(to right, #0a58ca, #004aad);
  color: #fff;
  border: none;
  padding: 0.7rem 1.6rem;
  font-size: 1rem;
  font-weight: 600;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-get-started:hover {
  background: linear-gradient(to right, #004aad, #003b94);
  transform: scale(1.05);
}
