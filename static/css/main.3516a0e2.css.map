body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f4f4f4;
}

.register-container {
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    background-color: #f8f9fa;
    /* border: 2px solid red; */
}

.register-image {
    width: 50%;
    height: 100vh;
    background-image: url('../../public/herosection2.jpg');
    background-size: cover;
    background-position: center;
}

.register-form-container {
    width: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    /* border: 2px solid blue; */
}

.register-card {
    background-color: white;
    width: 100%;
    max-width: 500px;
    padding: 30px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    /* border: 2px solid green; */
}

.register-header {
    text-align: center;
    font-size: 24px;
    font-weight: bold;
    color: #333;
    margin-bottom: 10px;
}

.register-subtext {
    text-align: center;
    color: #666;
    margin-bottom: 20px;
}

.input-error {
    /* border: 2px solid red; */
  }
  
  .error-message {
    color: red;
    font-size: 12px;
    margin-bottom: 5px;
  }
  




.register-form input {
    width: 90%;
    padding: 12px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 16px;
}

.register-button {
    width: 100%;
    padding: 12px;
    background-color: #28a745;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-size: 16px;
    transition: background 0.3s;
}

.register-button:hover {
    background-color: #218838;
}

/* Responsive Design */
@media (max-width: 1024px) {
    .register-card {
        padding: 20px;
    }
}

@media (max-width: 768px) {
    .register-container {
        flex-direction: column;
    }
    .register-image {
        width: 100%;
        height: 40vh;
    }
    .register-form-container {
        width: 90%;
        padding: 15px;
    }
    .register-card {
        max-width: 90%;
    }
}

@media (max-width: 480px) {
    .register-card {
        padding: 15px;
    }
    .register-header {
        font-size: 20px;
    }
    .register-subtext {
        font-size: 14px;
    }
    .register-form input {
        padding: 10px;
        font-size: 14px;
    }
    .register-button {
        padding: 10px;
        font-size: 14px;
    }
}
