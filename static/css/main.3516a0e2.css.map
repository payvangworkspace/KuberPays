/* Mobile responsiveness */
.mobile-menu-toggle {
  display: none;
  font-size: 1.5rem;
  color: #0077cc;
  cursor: pointer;
}

@media (max-width: 992px) {
  .navbar-menu {
    display: none;
    flex-direction: column;
    position: absolute;
    top: 75px;
    left: 0;
    right: 0;
    background-color: #fff;
    z-index: 999;
    padding: 1rem 2rem;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  }

  .navbar-menu.open {
    display: flex;
  }

  .navbar-item {
    margin-bottom: 1rem;
  }

  .dropdown-menu {
    position: relative;
    top: 0;
    left: 0;
    box-shadow: none;
    padding-left: 1rem;
    background-color: transparent;
  }

  .navbar-right {
    display: none;
  }

  .mobile-menu-toggle {
    display: block;
  }
}

@media (max-width: 576px) {
  .navbar-logo {
    width: 120px;
  }
}
@media (max-width: 992px) {
  .navbar-menu {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    position: absolute;
    top: 75px;
    left: 0;
    right: 0;
    background-color: #fff;
    z-index: 999;
    padding: 0.5rem 1.5rem;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  }

  .navbar-menu.open {
    display: flex;
  }

  .navbar-item {
    width: 100%;
    margin-bottom: 0.4rem;
  }

  .navbar-link {
    padding: 0.5rem 0;
    font-size: 1rem;
    width: 100%;
    border-bottom: 1px solid #e0e0e0;
  }

  .dropdown-menu {
    padding: 0.3rem 1rem;
    background: #f9f9f9;
    box-shadow: none;
  }

  .dropdown-item {
    padding: 0.4rem 0;
    font-size: 0.95rem;
    border-bottom: 1px dashed #ddd;
  }

  .navbar-right {
    display: none;
  }

  .mobile-menu-toggle {
    display: block;
  }
}
