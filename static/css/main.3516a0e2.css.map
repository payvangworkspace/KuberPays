.modern-stats-section {
  background: linear-gradient(135deg, #020c1b, #031b3a);

  /* background: linear-gradient(white,grey,black); */
  color: #ffffff;
  padding: 5rem 2rem;
  text-align: center;
  font-family: 'Inter', sans-serif;
}

.modern-stats-title {
  font-size: 2.6rem;
  font-weight: 800;
  color: #38bdf8;
  margin-bottom: 1rem;
}

.modern-stats-subtitle {
  font-size: 1.1rem;
  color: #b0c4d4;
  margin-bottom: 3rem;
}

.modern-stats-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2.5rem;
}

.modern-stat-box {
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(56, 189, 248, 0.15);
  border-radius: 20px;
  padding: 2rem 2.5rem;
  min-width: 200px;
  max-width: 240px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
  transition: all 0.3s ease;
  cursor: default;
}

.modern-stat-box:hover {
  transform: translateY(-5px);
  background: linear-gradient(135deg, #0f172a, #1e293b);
  border-color: #38bdf8;
  box-shadow: 0 12px 40px rgba(56, 189, 248, 0.25);
}

.modern-stat-value {
  font-size: 2.5rem;
  font-weight: 800;
  color: #38bdf8;
  margin-bottom: 0.6rem;
}

.modern-stat-label {
  font-size: 1.1rem;
  color: #cbd5e1;
  font-weight: 500;
}

@media (max-width: 768px) {
  .modern-stats-title {
    font-size: 2rem;
  }

  .modern-stat-box {
    padding: 1.5rem;
  }

  .modern-stat-value {
    font-size: 2rem;
  }
}
/* Section Container */
.stat-section {
  background: #f7fafe;
  padding: 5rem 2rem;
  font-family: "Inter", sans-serif;
  text-align: center;
}

/* Header Text */
.stat-header h2 {
  font-size: 2.5rem;
  color: #0f172a;
  font-weight: 800;
  margin-bottom: 0.5rem;
}

.stat-header p {
  color: #475569;
  font-size: 1.1rem;
  margin-bottom: 3rem;
}

/* Cards Grid */
.stat-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem;
}

/* Individual Card */
.stat-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 2rem 2.5rem;
  min-width: 220px;
  max-width: 250px;
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease-in-out;
}

.stat-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 32px rgba(14, 165, 233, 0.15);
}

/* Stat Value */
.stat-value {
  font-size: 2.8rem;
  font-weight: 800;
  color: #0ea5e9;
  margin-bottom: 0.5rem;
}

/* Stat Label */
.stat-label {
  font-size: 1.05rem;
  color: #64748b;
  font-weight: 500;
}

/* Responsive */
@media (max-width: 768px) {
  .stat-header h2 {
    font-size: 2rem;
  }

  .stat-value {
    font-size: 2.2rem;
  }

  .stat-label {
    font-size: 1rem;
  }
}
