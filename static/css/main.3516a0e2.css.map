.footer {
  background-color: #ffffff;
  padding: 3rem 2rem;
  border-top: 1px solid #e6e6e6;
  font-family: 'Inter', sans-serif;
  color: #406b7c;
  /* border:2px solid green; */
}

.footer-content {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
  max-width: 1200px;
  margin: 0 auto;
  /* border:2px solid orange; */
}

.footer-left {
  flex: 1;
  min-width: 280px;
   /* border: 2px solid blue; */
}
.logo-footer{

/* height: 70px;
width: 140px; */
  width: 180px;
  height: auto;
  height: 198px;
/* border:2px solid red; */
/* height:"100px",width:"120px" */
/* border: 2px solid red; */
}

.footer-left .logo {
  font-size: 1.6rem;
  font-weight: 700;
  color: #003c57;
  margin-bottom: 0.5rem;
}

.footer-left p {
  margin: 0.3rem 0;
  line-height: 1.6;
  font-size: 0.95rem;
   /* border: 2px solid red; */
}

.footer-left .icon {
  color: #0077b6;
  margin-right: 8px;
  vertical-align: middle;
}

.footer-right {
  flex: 1;
  text-align: right;
  /* min-width: 200px; */
  /* margin-top: 1rem; */
  /* border:2px solid red; */
  height: 40vh;
  /* width: 30vw; */
  display: flex;
  justify-content: center;
  align-items:end;
  padding-bottom: 15px;
}

.footer-right .copyright {
  font-size: 0.9rem;
  color:rgb(44, 117, 148);
  font-weight: 600;


}
.copyright{
  /* border: 3px solid rebeccapurple; */
  height: 30px;
}

.footer-para-left{
  margin-top: -50px;
  /* border:2px solid black; */
}



/* Responsive */
@media (max-width: 768px) {
  .footer-content {
    flex-direction: column;
    text-align: center;
  }

  .footer-right {
    text-align: center;
    margin-top: 2rem;
  }
}
